{
  "name": "djzg",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development NODE_OPTIONS=--max_old_space_size=4096 BASE=development nuxt",
    "start:uat": "cross-env NODE_ENV=uat BASE=uat nuxt start",
    "start:prod": "cross-env NODE_ENV=production BASE=production nuxt start",
    "start:stagging": "cross-env NODE_ENV=stagging BASE=stagging nuxt start",
    "build:dev": "cross-env NODE_ENV=development BASE=development nuxt build",
    "build:uat": "cross-env NODE_ENV=uat BASE=uat nuxt build",
    "build:prod": "cross-env NODE_ENV=production NODE_OPTIONS=--max_old_space_size=4096 BASE=production nuxt build",
    "build:stagging": "cross-env NODE_ENV=stagging BASE=stagging nuxt build",
    "generate": "nuxt generate",
    "lint:js": "eslint --ext .js,.vue --ignore-path .gitignore ./pages/ir",
    "lint:style": "stylelint **/*.{vue,css} --ignore-path .gitignore ./pages/ir",
    "lint": "npm run lint:js && npm run lint:style",
    "analysis:uat": "npm run build:uat --report",
    "prepare": "husky install",
    "lint:staged": "lint-staged"
  },
  "config": {
    "nuxt": {
      "host": "0.0.0.0",
      "port": 3000
    }
  },
  "lint-staged": {
